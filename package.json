{
  "name": "agent-board",
  "displayName": "Agent Board",
  "description": "Manage tasks. Run agents.",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/calca/agent-board.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-board",
          "title": "Agent Board",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agent-board": [
        {
          "id": "agentBoardTasks",
          "name": "Tasks"
        },
        {
          "id": "agentBoardAgents",
          "name": "Agents"
        }
      ]
    },
    "commands": [
      {
        "command": "agentBoard.addTask",
        "title": "Add Task",
        "icon": "$(add)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.completeTask",
        "title": "Complete Task",
        "icon": "$(check)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.deleteTask",
        "title": "Delete Task",
        "icon": "$(trash)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.runAgent",
        "title": "Run Agent",
        "icon": "$(play)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.stopAgent",
        "title": "Stop Agent",
        "icon": "$(stop-circle)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.refreshTasks",
        "title": "Refresh Tasks",
        "icon": "$(refresh)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.editTask",
        "title": "Edit Task",
        "icon": "$(edit)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.openKanban",
        "title": "Open Kanban Board",
        "icon": "$(preview)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.selectProvider",
        "title": "Select Task Provider",
        "icon": "$(plug)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.launchCopilot",
        "title": "Launch Copilot for Task",
        "icon": "$(copilot)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.startSquad",
        "title": "Start Squad Session",
        "icon": "$(run-all)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.toggleAutoSquad",
        "title": "Toggle Auto Squad",
        "icon": "$(sync)",
        "category": "Agent Board"
      }
    ],
    "keybindings": [
      {
        "command": "agentBoard.openKanban",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      }
    ],
    "configuration": {
      "title": "Agent Board",
      "properties": {
        "agentBoard.github.owner": {
          "type": "string",
          "default": "",
          "description": "Default GitHub repository owner (user or organization). Used when not specified in .agent-board/config.json. If empty, the GitHub SSO account name is used as fallback."
        },
        "agentBoard.github.repo": {
          "type": "string",
          "default": "",
          "description": "Default GitHub repository name. Used when not specified in .agent-board/config.json."
        },
        "agentBoard.jsonProvider.path": {
          "type": "string",
          "default": ".agent-board/tasks",
          "description": "Workspace-relative or absolute path to a JSON file containing tasks for the JSON provider. Overridable in .agent-board/config.json."
        },
        "agentBoard.beadsProvider.executable": {
          "type": "string",
          "default": "beads",
          "description": "Path to the Beads CLI executable. Overridable in .agent-board/config.json."
        },
        "agentBoard.worktree.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Create an isolated git worktree for providers that support it (e.g. Copilot CLI). Overridable in .agent-board/config.json."
        },
        "agentBoard.kanban.columns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "todo",
            "inprogress",
            "review",
            "done"
          ],
          "description": "Ordered list of Kanban column identifiers. Overridable in .agent-board/config.json."
        },
        "agentBoard.pollInterval": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "description": "Polling interval in milliseconds for providers that use polling (e.g. Beads). Overridable in .agent-board/config.json."
        },
        "agentBoard.logLevel": {
          "type": "string",
          "enum": [
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR"
          ],
          "default": "INFO",
          "description": "Log level for the Agent Board output channel. Overridable in .agent-board/config.json."
        },
        "agentBoard.squad.maxSessions": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "description": "Maximum number of parallel agent sessions launched by the squad feature. Overridable in .agent-board/config.json."
        },
        "agentBoard.squad.sourceColumn": {
          "type": "string",
          "default": "todo",
          "description": "Column from which the squad picks tasks to launch. Overridable in .agent-board/config.json."
        },
        "agentBoard.squad.activeColumn": {
          "type": "string",
          "default": "inprogress",
          "description": "Column tasks are moved to when the agent starts working. Overridable in .agent-board/config.json."
        },
        "agentBoard.squad.doneColumn": {
          "type": "string",
          "default": "review",
          "description": "Column tasks are moved to when the agent completes. Overridable in .agent-board/config.json."
        },
        "agentBoard.notifications.taskStarted": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code notification when a task is automatically moved to the active column. Overridable in .agent-board/config.json."
        },
        "agentBoard.notifications.taskCompleted": {
          "type": "boolean",
          "default": true,
          "description": "Show a VS Code notification when a task is automatically moved to the done column. Overridable in .agent-board/config.json."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "agentBoard.addTask",
          "when": "view == agentBoardTasks",
          "group": "navigation"
        },
        {
          "command": "agentBoard.refreshTasks",
          "when": "view == agentBoardTasks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agentBoard.completeTask",
          "when": "view == agentBoardTasks && viewItem == task-pending",
          "group": "inline"
        },
        {
          "command": "agentBoard.editTask",
          "when": "view == agentBoardTasks && viewItem =~ /^task-/",
          "group": "inline"
        },
        {
          "command": "agentBoard.deleteTask",
          "when": "view == agentBoardTasks && viewItem =~ /^task-/",
          "group": "inline"
        },
        {
          "command": "agentBoard.runAgent",
          "when": "view == agentBoardAgents && viewItem == agent-idle",
          "group": "inline"
        },
        {
          "command": "agentBoard.stopAgent",
          "when": "view == agentBoardAgents && viewItem == agent-running",
          "group": "inline"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": ".agent-board/config.json",
        "url": "./schemas/agent-board-config.schema.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "mocha out/test/suite/taskStore.test.js out/test/suite/agentManager.test.js out/test/suite/providerRegistry.test.js out/test/suite/columnId.test.js out/test/suite/aggregatorProvider.test.js out/test/suite/schema.test.js out/test/suite/contextBuilder.test.js out/test/suite/messages.test.js out/test/suite/projectConfig.test.js out/test/suite/githubProvider.test.js out/test/suite/genAiProvider.test.js out/test/suite/worktreeManager.test.js out/test/suite/squadManager.test.js --ui tdd --reporter spec"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.27.4",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3"
  }
}
