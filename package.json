{
  "name": "agent-board",
  "displayName": "Agent Board",
  "description": "Manage tasks. Run agents.",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent-board",
          "title": "Agent Board",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agent-board": [
        {
          "id": "agentBoardTasks",
          "name": "Tasks"
        },
        {
          "id": "agentBoardAgents",
          "name": "Agents"
        }
      ]
    },
    "commands": [
      {
        "command": "agentBoard.addTask",
        "title": "Add Task",
        "icon": "$(add)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.completeTask",
        "title": "Complete Task",
        "icon": "$(check)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.deleteTask",
        "title": "Delete Task",
        "icon": "$(trash)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.runAgent",
        "title": "Run Agent",
        "icon": "$(play)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.stopAgent",
        "title": "Stop Agent",
        "icon": "$(stop-circle)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.refreshTasks",
        "title": "Refresh Tasks",
        "icon": "$(refresh)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.editTask",
        "title": "Edit Task",
        "icon": "$(edit)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.openKanban",
        "title": "Open Kanban Board",
        "icon": "$(preview)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.selectProvider",
        "title": "Select Task Provider",
        "icon": "$(plug)",
        "category": "Agent Board"
      },
      {
        "command": "agentBoard.launchCopilot",
        "title": "Launch Copilot for Task",
        "icon": "$(copilot)",
        "category": "Agent Board"
      }
    ],
    "keybindings": [
      {
        "command": "agentBoard.openKanban",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k"
      }
    ],
    "configuration": {
      "title": "Agent Board",
      "properties": {
        "agentBoard.github.token": {
          "type": "string",
          "default": "",
          "description": "GitHub personal access token for the GitHub task provider. For better security, prefer storing the token in VSCode SecretStorage.",
          "markdownDescription": "GitHub personal access token for the GitHub task provider. For better security, prefer storing the token via the **Accounts** menu."
        },
        "agentBoard.github.owner": {
          "type": "string",
          "default": "",
          "description": "GitHub repository owner (user or org) for the GitHub task provider."
        },
        "agentBoard.github.repo": {
          "type": "string",
          "default": "",
          "description": "GitHub repository name for the GitHub task provider."
        },
        "agentBoard.jsonProvider.path": {
          "type": "string",
          "default": "",
          "description": "Absolute or workspace-relative path to a JSON file containing tasks for the JSON provider."
        },
        "agentBoard.beadsProvider.executable": {
          "type": "string",
          "default": "beads",
          "description": "Path to the Beads CLI executable."
        },
        "agentBoard.copilot.defaultMode": {
          "type": "string",
          "enum": [
            "chat",
            "cloud",
            "local",
            "background"
          ],
          "default": "chat",
          "description": "Default Copilot mode when launching a task session.",
          "enumDescriptions": [
            "Open VS Code chat with task context pre-filled",
            "Use GitHub Copilot cloud model",
            "Use a local Ollama model",
            "Run in background and save result to a file"
          ]
        },
        "agentBoard.copilot.localModel": {
          "type": "string",
          "default": "llama3",
          "description": "Ollama model name to use in local Copilot mode."
        },
        "agentBoard.kanban.columns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "todo",
            "inprogress",
            "review",
            "done"
          ],
          "description": "Ordered list of Kanban column identifiers."
        },
        "agentBoard.pollInterval": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "description": "Polling interval in milliseconds for providers that use polling (e.g. Beads)."
        },
        "agentBoard.logLevel": {
          "type": "string",
          "enum": [
            "DEBUG",
            "INFO",
            "WARN",
            "ERROR"
          ],
          "default": "INFO",
          "description": "Log level for the Task Kanban output channel."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "agentBoard.addTask",
          "when": "view == agentBoardTasks",
          "group": "navigation"
        },
        {
          "command": "agentBoard.refreshTasks",
          "when": "view == agentBoardTasks",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agentBoard.completeTask",
          "when": "view == agentBoardTasks && viewItem == task-pending",
          "group": "inline"
        },
        {
          "command": "agentBoard.editTask",
          "when": "view == agentBoardTasks && viewItem =~ /^task-/",
          "group": "inline"
        },
        {
          "command": "agentBoard.deleteTask",
          "when": "view == agentBoardTasks && viewItem =~ /^task-/",
          "group": "inline"
        },
        {
          "command": "agentBoard.runAgent",
          "when": "view == agentBoardAgents && viewItem == agent-idle",
          "group": "inline"
        },
        {
          "command": "agentBoard.stopAgent",
          "when": "view == agentBoardAgents && viewItem == agent-running",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "mocha out/test/suite/taskStore.test.js out/test/suite/agentManager.test.js out/test/suite/providerRegistry.test.js out/test/suite/columnId.test.js out/test/suite/aggregatorProvider.test.js out/test/suite/schema.test.js out/test/suite/contextBuilder.test.js out/test/suite/messages.test.js --ui tdd --reporter spec"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.27.4",
    "eslint": "^8.56.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.3.3"
  }
}
